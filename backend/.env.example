# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root_password
DB_NAME=ecommercemrcode
DB_PORT=3306

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# SEGURIDAD
# ============================================
# Clave secreta para JWT (cambiar en producción)
JWT_SECRET=ecommerce_perfumes_secret_key_2026_CHANGE_THIS_IN_PRODUCTION

# Orígenes permitidos para CORS (separados por comas)
# En desarrollo: http://localhost:5173,http://localhost:5175
# En producción: https://tudominio.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5175

# ============================================
# MERCADO PAGO
# ============================================
# Obtener en: https://www.mercadopago.com.ar/developers/panel/credentials
MERCADOPAGO_ACCESS_TOKEN=tu_access_token_aqui
MERCADOPAGO_PUBLIC_KEY=tu_public_key_aqui

# ============================================
# CONFIGURACIÓN DE EMAIL
# ============================================
# Proveedor de email (Gmail, SendGrid, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false

# Credenciales de email
# Para Gmail: habilitar "Aplicaciones menos seguras" o usar "Contraseñas de aplicación"
# https://support.google.com/accounts/answer/185833
EMAIL_USER=tu_email@gmail.com
EMAIL_PASSWORD=tu_contraseña_o_app_password

# Nombre que aparecerá como remitente
EMAIL_FROM_NAME=Perfumería E-commerce

# ============================================
# FRONTEND URL
# ============================================
# URL del frontend para links en emails (recuperación de contraseña, etc.)
# En desarrollo: http://localhost:5173
# En producción: https://tudominio.com
FRONTEND_URL=http://localhost:5173

# ============================================
# WHATSAPP (OPCIONAL)
# ============================================
# Si usas WhatsApp Web.js, no requiere configuración adicional
# Solo escanear QR al iniciar el servidor
